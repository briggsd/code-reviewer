{
  "name": "@briggsd/code-reviewer",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Reusable CI-native AI code review system for GitHub and GitLab projects.",
  "homepage": "https://github.com/briggsd/code-reviewer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briggsd/code-reviewer.git"
  },
  "bugs": {
    "url": "https://github.com/briggsd/code-reviewer/issues"
  },
  "exports": {
    ".": "./src/public.ts"
  },
  "bin": {
    "code-reviewer": "./src/cli.ts"
  },
  "scripts": {
    "review:local": "bun run src/cli.ts run --git-diff",
    "check": "bunx tsc --noEmit && bun test",
    "gate": "bun run check && bun run boundaries && bun run lint && bun run docs:check && bun run complexity:check && bun run workflows:check && bun run knip",
    "test": "bun test",
    "start": "bun run src/cli.ts",
    "workflows:check": "bun run scripts/check-workflows.ts",
    "complexity:check": "bun run scripts/check-complexity.ts",
    "complexity:update": "bun run scripts/check-complexity.ts --update",
    "docs:check": "bun run scripts/check-docs.ts",
    "docs:stale": "bun run scripts/check-docs.ts --mode=advisory",
    "schema:config": "bun run scripts/write-config-schema.ts",
    "telemetry:rollup": "bun run scripts/telemetry-rollup.ts",
    "telemetry:analyze": "bun run scripts/telemetry-analyze.ts",
    "telemetry:quality": "bun run scripts/telemetry-quality-report.ts",
    "telemetry:ingest": "bun run scripts/telemetry-ingest.ts",
    "telemetry:backfill-loki": "bun run scripts/telemetry-backfill-loki.ts",
    "pack:compile": "bun run scripts/package-compile.ts",
    "compile:smoke": "bun run scripts/compile-smoke.ts",
    "pack:smoke": "bun run scripts/package-smoke.ts",
    "smoke:external-package": "bun run scripts/external-package-smoke.ts",
    "smoke:pi": "bun run scripts/pi-live-smoke.ts",
    "smoke:gitlab": "bun run scripts/gitlab-live-smoke.ts",
    "smoke:action-wrapper": "bun run scripts/action-wrapper-smoke.ts",
    "spike:structured-output": "bun run scripts/structured-output-spike.ts",
    "evals": "bun run scripts/evals.ts",
    "boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "dup": "jscpd src"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    ".ai-review.schema.json",
    "NOTICE",
    "README.md",
    "docs/user",
    "examples/ci",
    "examples/fixtures",
    "scripts",
    "src",
    "tsconfig.json"
  ],
  "keywords": [
    "code-review",
    "ci",
    "github",
    "gitlab",
    "ai-review"
  ],
  "license": "Apache-2.0",
  "author": "The Code Reviewer Authors",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.3.14",
    "dependency-cruiser": "^17.4.3",
    "jscpd": "^5.0.7",
    "knip": "^6.16.1",
    "typescript": "^6.0.3"
  }
}
